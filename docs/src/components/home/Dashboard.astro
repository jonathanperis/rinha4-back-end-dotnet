---
const official = await import('../../../public/official/latest.json');
const latest = await import('../../../public/reports/latest-candidate.json');
const index = await import('../../../public/reports/index.json');
const officialResult = official.default.result;
const officialIssue = official.default.issue;
const officialComment = official.default.comment;
const officialSource = official.default.source;
const result = latest.default.result;
const metadata = latest.default.metadata;
const runs = index.default;
const candidates = runs.filter((run) => run.report_kind === 'candidate');
const calibrated = runs.filter((run) => run.report_kind === 'official-calibrated');
const experiments = runs.filter((run) => run.report_kind === 'experiment');
const latestCalibrated = calibrated[0];
const officialScore = Number(officialResult.scoring.final_score).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const officialClosedAt = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(officialIssue.closed_at));
const score = Number(result.scoring.final_score).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const p99Score = Number(result.scoring.p99_score.value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const detectionScore = Number(result.scoring.detection_score.value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---

<section class="stats-grid">
  <div class="stat-box">
    <div class="stat-label">Official p99</div>
    <div class="stat-value">{officialResult.p99}</div>
    <div class="stat-sub">Rinha runner</div>
  </div>
  <div class="stat-box danger">
    <div class="stat-label">Official failures</div>
    <div class="stat-value">{officialResult.scoring.failure_rate}</div>
    <div class="stat-sub">Target is 0%</div>
  </div>
  <div class="stat-box warning">
    <div class="stat-label">Official score</div>
    <div class="stat-value">{officialScore}</div>
    <div class="stat-sub">Public ranking number</div>
  </div>
  <div class="stat-box">
    <div class="stat-label">Official issue</div>
    <div class="stat-value">#{officialIssue.number}</div>
    <div class="stat-sub">{officialClosedAt} UTC</div>
  </div>
</section>

<section class="official-strip">
  <div>
    <span class="official-kicker">official source</span>
    <p>Latest closed completed upstream issue authored by <code>{officialSource.author}</code>, synced through <code>gh</code> from <code>{officialSource.repo}</code>.</p>
  </div>
  <div class="official-links">
    <a href={officialIssue.url} target="_blank" rel="noopener noreferrer">Issue #{officialIssue.number}</a>
    <a href={officialComment.url} target="_blank" rel="noopener noreferrer">Result comment</a>
    <a href="https://rinhadebackend.com.br/" target="_blank" rel="noopener noreferrer">Ranking</a>
  </div>
</section>

<h2 class="section-title">SYSTEM TOPOLOGY</h2>
<section class="scenarios">
  <div class="scenario-card">
    <h3>Transport Path</h3>
    <div class="endpoint"><span class="method get">GET</span> /ready</div>
    <p>The standalone yolo load balancer accepts port 9999 and forwards raw HTTP to two API containers through Unix Domain Sockets. The app parses enough HTTP/1 to satisfy the Rinha workload.</p>
    <div class="progress-container">
      <div class="progress-label">Latency path [||||||||||||||||||..] tuned</div>
    </div>
  </div>
  <div class="scenario-card">
    <h3>Fraud Decision</h3>
    <div class="endpoint"><span class="method post">POST</span> /fraud-score</div>
    <p>Manual JSON parsing extracts only the required fields, vectorizes into 14 dimensions, scores with rounded int16 IVF, and writes one prebuilt HTTP response.</p>
    <div class="progress-container">
      <div class="progress-label danger-text">p99 gap [|||||...............] active</div>
    </div>
  </div>
</section>

<section class="stress-tests">
  <h3>CI BENCHMARK STREAM</h3>
  <p class="stress-intro">
    CI candidate metrics stay below as local evidence. The hero and top cards use official Rinha issue results, not GitHub Actions runner numbers.
  </p>

  <div class="stress-metrics">
    <div class="stress-metric">
      <span class="metric-value">{result.p99}</span>
      <span class="metric-label">CI p99</span>
    </div>
    <div class="stress-metric">
      <span class="metric-value">{result.scoring.failure_rate}</span>
      <span class="metric-label">CI failures</span>
    </div>
    <div class="stress-metric">
      <span class="metric-value">{score}</span>
      <span class="metric-label">CI score</span>
    </div>
    {latestCalibrated && (
      <div class="stress-metric">
        <span class="metric-value">{latestCalibrated.p99}</span>
        <span class="metric-label">calibrated p99</span>
      </div>
    )}
  </div>

  <div class="stress-links">
    <a href="./reports/" class="stress-link">View report history</a>
    <a href={metadata.run_url} class="stress-link" target="_blank" rel="noopener noreferrer">Latest CI run</a>
    <span class="stress-link ghost">p99 score {p99Score} // detection {detectionScore}</span>
  </div>
</section>
