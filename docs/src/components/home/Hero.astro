---
const official = await import('../../../public/official/latest.json');
const result = official.default.result;
const issue = official.default.issue;
---

<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">RINHA 2026 // .NET 10 NATIVEAOT</p>
    <h1>FRAUD SIGNAL<br />UNDER LOAD.</h1>
    <p class="tagline">
      Raw HTTP/1 over Unix sockets, precomputed byte responses, and hybrid bucket/IVF scoring while chasing 0% failures.
    </p>
    <div class="cta-group">
      <a href={issue.url} class="btn-fire" target="_blank" rel="noopener noreferrer">OFFICIAL RESULT</a>
      <a href="./docs/" class="btn-secondary">READ SYSTEM NOTES</a>
    </div>
  </div>

  <div class="terminal-panel">
    <div class="terminal-content">
      <div class="term-line">&gt; docker pull ghcr.io/jonathanperis/rinha4-back-end-dotnet:latest</div>
      <div class="term-line">&gt; reverse_proxy: yolo_mode // uds</div>
      <div class="term-line">&gt; native_aot: ready // parser: raw_http</div>
      <div class="term-line">&gt; official.issue = #{issue.number}</div>
      <div class="term-line">&gt; official.p99 = {result.p99}</div>
      <div class="term-line">&gt; official.failures = {result.scoring.failure_rate}</div>
      <div class="term-line">&gt; target: 0% failures, p99 near 1ms</div>
      <div class="term-line">&gt; <span class="cursor"></span></div>
    </div>
  </div>
</section>
