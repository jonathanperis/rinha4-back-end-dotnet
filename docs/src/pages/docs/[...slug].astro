---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '../../styles/docs.css';
import { SECTION_CATEGORIES, SECTION_ORDER } from './sidebar.config';

const SLUG_LABEL: Record<string, string> = {
  home: 'Home',
  architecture: 'Architecture',
  challenge: 'Challenge',
  rules: 'Rules',
  'ci-cd-pipeline': 'CI/CD Pipeline',
  'getting-started': 'Getting Started',
  performance: 'Performance',
};

const globResult = import.meta.glob('../../../wiki/*.md', { eager: true });

const pagesBySlug: Record<string, any> = {};
for (const [path, module] of Object.entries(globResult)) {
  const fileName = path.split('/').pop()!.replace('.md', '');
  pagesBySlug[fileName] = module;
}

const availableSlugs = new Set(Object.keys(pagesBySlug));
for (const cat of SECTION_CATEGORIES) {
  for (const id of cat.ids) {
    if (!availableSlugs.has(id)) {
      throw new Error(`sidebar id "${id}" has no matching wiki/${id}.md`);
    }
  }
}

const requestedSlug = Astro.params.slug;
const isRoot = requestedSlug === undefined;
const requestedKey = requestedSlug ?? 'home';

const sectionsToRender = isRoot
  ? SECTION_CATEGORIES.flatMap(cat => cat.ids).map(slug => ({ slug, page: pagesBySlug[slug] })).filter(s => s.page)
  : pagesBySlug[requestedKey] ? [{ slug: requestedSlug!, page: pagesBySlug[requestedKey] }] : [];

export function getStaticPaths() {
  return [
    { params: { slug: undefined } },
    ...SECTION_ORDER.filter(s => s !== 'home').map(slug => ({ params: { slug } })),
  ];
}

const pageTitle = isRoot ? 'rinha4-back-end-dotnet | Docs' : `${SLUG_LABEL[requestedSlug] ?? requestedSlug} | rinha4-back-end-dotnet`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const docsBase = `${base}/docs`;
---

<BaseLayout title={pageTitle}>
  <div class="docs-shell">
    <div class="mobile-header">
      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-controls="sidebar" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="repo-title">rinha4.dotnet</div>
    </div>

    <div class="overlay" id="overlay"></div>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h1 class="repo-title">rinha4.dotnet</h1>
        <p class="repo-description">NativeAOT fraud scorer. Raw socket HTTP. Official-like benchmark archive.</p>
        <input type="text" id="searchInput" class="search-box" placeholder="Search docs..." aria-label="Search docs" hidden={!isRoot}>
      </div>
      <div class="sidebar-nav-container">
        {SECTION_CATEGORIES.map((cat) => (
          <div class="sidebar-category-group" data-category>
            {cat.label && <div class="sidebar-category">{cat.label}</div>}
            <ul>
              {cat.ids.map((id) => (
                <li><a class="nav-item" href={`${docsBase}/#${id}`} data-nav-id={id}>{SLUG_LABEL[id]}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="sidebar-footer">
        <a href={`${base}/`}>Back home</a>
        <a href={`${base}/reports/`}>Benchmark reports</a>
        <a href="https://github.com/jonathanperis/rinha4-back-end-dotnet" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </aside>

    <div class="content-wrapper">
      <main class="content" id="mainContent">
        {sectionsToRender.map(({ slug, page: wikiPage }) => {
          const Content = wikiPage.default ?? wikiPage;
          return <section id={slug} class="doc-section"><Content /></section>;
        })}
      </main>
    </div>
  </div>

  <script is:inline define:vars={{ requestedSlug, isRoot }}>
    window.__docsSlug = requestedSlug;
    window.__isRoot = isRoot;
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      const sections = document.querySelectorAll('section.doc-section');
      const navItems = document.querySelectorAll('.nav-item');

      function toggleMenu() {
        const isOpen = sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
        if (menuToggle) menuToggle.setAttribute('aria-expanded', String(isOpen));
      }

      if (menuToggle) menuToggle.addEventListener('click', toggleMenu);
      if (overlay) overlay.addEventListener('click', toggleMenu);

      if (window.__isRoot && sections.length > 1) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            navItems.forEach(item => item.classList.toggle('active', item.dataset.navId === entry.target.id));
          });
        }, { rootMargin: '-80px 0px -60% 0px' });

        sections.forEach(section => observer.observe(section));
      }

      navItems.forEach(item => {
        item.addEventListener('click', () => {
          if (window.innerWidth <= 820) toggleMenu();
        });
      });

      const searchInput = document.getElementById('searchInput');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          sections.forEach(section => {
            const match = !query || (section.textContent || '').toLowerCase().includes(query);
            section.classList.toggle('hidden-section', !match);
            const navItem = document.querySelector(`.nav-item[data-nav-id="${section.id}"]`);
            if (navItem && navItem.parentElement) navItem.parentElement.style.display = match ? '' : 'none';
          });
        });
      }
    });
  </script>
</BaseLayout>
