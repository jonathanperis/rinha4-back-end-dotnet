---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/home/Navbar.astro';
import Footer from '@/components/home/Footer.astro';

const reports = await import('../../../public/reports/index.json');
const rows = reports.default;
const candidates = rows.filter((row) => row.report_kind === 'candidate');
const experiments = rows.filter((row) => row.report_kind === 'experiment');
const latest = candidates[0];
const pageSize = 5;
const fmtScore = (n: number) => n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---

<BaseLayout title="rinha4-back-end-dotnet | Benchmark Reports">
  <Navbar />
  <main>
    <section class="reports-hero">
      <p class="eyebrow">CI BENCHMARK ARCHIVE</p>
      <h1>OFFICIAL-LIKE RUN LOG.</h1>
      <p class="tagline">
        Candidate runs track the default submission stack. Experiment runs stay visible with their own error data.
      </p>
    </section>

    {latest && (
      <section class="stats-grid compact">
        <div class="stat-box">
          <div class="stat-label">Latest p99</div>
          <div class="stat-value">{latest.p99}</div>
          <div class="stat-sub">{latest.short_sha}</div>
        </div>
        <div class="stat-box danger">
          <div class="stat-label">Failures</div>
          <div class="stat-value">{latest.failure_rate}</div>
          <div class="stat-sub">Target is 0%</div>
        </div>
        <div class="stat-box warning">
          <div class="stat-label">Score</div>
          <div class="stat-value">{fmtScore(latest.final_score)}</div>
          <div class="stat-sub">Official-like</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">HTTP errors</div>
          <div class="stat-value">{latest.http_errors}</div>
          <div class="stat-sub">Must stay zero</div>
        </div>
      </section>
    )}

    <section class="report-table-wrap" data-paginated-table data-page-size={pageSize}>
      <div class="report-scroll">
        <table class="report-table">
          <thead>
            <tr>
              <th>Run</th>
              <th class="num">p99</th>
              <th class="num">Failures</th>
              <th class="num">Score</th>
              <th class="num">HTTP</th>
              <th>Files</th>
            </tr>
          </thead>
          <tbody>
            {candidates.map((row) => (
              <tr data-page-row>
                <td>
                  <a href={row.run_url} target="_blank" rel="noopener noreferrer">{new Date(row.timestamp).toLocaleString('sv-SE')}</a>
                  <code>{row.short_sha}</code>
                  <code>{row.compose_file}</code>
                  {row.scorer_mode && <code>{row.scorer_mode}</code>}
                </td>
                <td class="num">{row.p99}</td>
                <td class="num danger-text">{row.failure_rate}</td>
                <td class="num">{fmtScore(row.final_score)}</td>
                <td class="num">{row.http_errors}</td>
                <td>
                  <span class="file-links">
                    <a href={`../reports/${row.file}`} target="_blank" rel="noopener noreferrer">json</a>
                    {row.html_report && <a href={`../reports/${row.html_report}`} target="_blank" rel="noopener noreferrer">html</a>}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <nav class="pagination" data-pagination aria-label="Candidate run pages">
        <button type="button" data-page-prev>Prev</button>
        <span data-page-status></span>
        <button type="button" data-page-next>Next</button>
      </nav>
    </section>

    {experiments.length > 0 && (
      <section class="report-table-wrap experiment-wrap" data-paginated-table data-page-size={pageSize}>
        <h2>Experiment Runs</h2>
        <p>Failed or alternate runs stay here for evidence, not candidate status.</p>
        <div class="report-scroll">
          <table class="report-table">
            <thead>
              <tr>
                <th>Run</th>
                <th class="num">p99</th>
                <th class="num">Failures</th>
                <th class="num">Score</th>
                <th class="num">HTTP</th>
                <th>Files</th>
              </tr>
            </thead>
            <tbody>
              {experiments.map((row) => (
                <tr data-page-row>
                  <td>
                    <a href={row.run_url} target="_blank" rel="noopener noreferrer">{new Date(row.timestamp).toLocaleString('sv-SE')}</a>
                    <code>{row.short_sha}</code>
                    <code>{row.compose_file}</code>
                    {row.scorer_mode && <code>{row.scorer_mode}</code>}
                    {row.ivf_fast_nprobe && <code>n{row.ivf_fast_nprobe}/{row.ivf_full_nprobe}</code>}
                  </td>
                  <td class="num">{row.p99}</td>
                  <td class="num danger-text">{row.failure_rate}</td>
                  <td class="num">{fmtScore(row.final_score)}</td>
                  <td class="num">{row.http_errors}</td>
                  <td>
                    <span class="file-links">
                      <a href={`../reports/${row.file}`} target="_blank" rel="noopener noreferrer">json</a>
                      {row.html_report && <a href={`../reports/${row.html_report}`} target="_blank" rel="noopener noreferrer">html</a>}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <nav class="pagination" data-pagination aria-label="Experiment run pages">
          <button type="button" data-page-prev>Prev</button>
          <span data-page-status></span>
          <button type="button" data-page-next>Next</button>
        </nav>
      </section>
    )}
  </main>
  <Footer />

  <script is:inline>
    for (const tableWrap of document.querySelectorAll('[data-paginated-table]')) {
      const rows = Array.from(tableWrap.querySelectorAll('[data-page-row]'));
      const pageSize = Number(tableWrap.dataset.pageSize || 5);
      const pageCount = Math.max(1, Math.ceil(rows.length / pageSize));
      const pagination = tableWrap.querySelector('[data-pagination]');
      const status = tableWrap.querySelector('[data-page-status]');
      const prev = tableWrap.querySelector('[data-page-prev]');
      const next = tableWrap.querySelector('[data-page-next]');
      let page = 0;

      if (!pagination || !status || !prev || !next) continue;
      if (rows.length <= pageSize) pagination.hidden = true;

      const render = () => {
        const start = page * pageSize;
        const end = start + pageSize;
        rows.forEach((row, index) => {
          row.hidden = index < start || index >= end;
        });
        status.textContent = `${page + 1} / ${pageCount}`;
        prev.disabled = page === 0;
        next.disabled = page === pageCount - 1;
      };

      prev.addEventListener('click', () => {
        page = Math.max(0, page - 1);
        render();
      });

      next.addEventListener('click', () => {
        page = Math.min(pageCount - 1, page + 1);
        render();
      });

      render();
    }
  </script>
</BaseLayout>

<style>
  .reports-hero { margin-bottom: 3rem; }
  .reports-hero h1 {
    color: var(--term-green);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    text-shadow: 2px 2px 0 var(--kill-red), -2px -2px 0 var(--warn-amber);
  }
  .reports-hero code {
    color: var(--term-green-soft);
    background: rgba(0, 255, 65, 0.08);
    border: 1px solid var(--term-green-dim);
    padding: 0.1rem 0.35rem;
  }
  .compact { margin-bottom: 3rem; }
  .report-table-wrap {
    border: 1px solid var(--term-green-dim);
    background: rgba(0, 8, 0, 0.72);
    box-shadow: inset 0 0 40px rgba(0, 255, 65, 0.035);
  }
  .report-scroll { overflow-x: auto; }
  .experiment-wrap {
    margin-top: 3rem;
    border-color: rgba(255, 179, 0, 0.45);
  }
  .experiment-wrap h2 {
    color: var(--warn-amber);
    padding: 1rem 1rem 0;
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .experiment-wrap p {
    color: var(--text-muted);
    padding: 0 1rem 1rem;
  }
  .report-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }
  .report-table th,
  .report-table td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--term-green-dim);
    text-align: left;
  }
  .report-table th {
    color: var(--term-green);
    background: rgba(0, 255, 65, 0.08);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .report-table td { color: var(--text-main); }
  .report-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .report-table a { color: var(--term-green-soft); text-decoration: none; }
  .report-table a:hover { text-shadow: 0 0 10px var(--term-green-glow); }
  .file-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .pagination {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border-top: 1px solid var(--term-green-dim);
  }
  .pagination[hidden] { display: none; }
  .pagination button {
    min-width: 4.5rem;
    border: 1px solid var(--term-green-dim);
    background: rgba(92, 255, 177, 0.08);
    color: var(--term-green);
    font: inherit;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }
  .pagination button:hover:not(:disabled) {
    background: var(--term-green);
    color: var(--bg-deep);
    box-shadow: 0 0 14px var(--term-green-glow);
  }
  .pagination button:disabled {
    color: var(--text-muted);
    cursor: default;
    opacity: 0.52;
  }
  .pagination span {
    color: var(--text-muted);
    min-width: 4rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .report-table code {
    display: block;
    margin-top: 0.25rem;
    color: var(--text-muted);
    font-size: 0.78rem;
  }
</style>
